# Copy this file to .env.local or run scripts/setup_local_env.ps1.
# Never commit .env.local or real API keys.

# Required for reliable SEC access.
SEC_USER_AGENT="Your Name your.email@example.com"

# MVP cost posture: Free, Lean, Stable, or Premium.
BUDGET_MODE="Lean"
BUDGET_POLICY_PATH="data/budget_modes.json"
BYOD_DATA_DIR="data/manual_import"

# Consensus, recommendations, and transcript/overview sources.
ALPHAVANTAGE_API_KEY=""
FINNHUB_API_KEY=""

# Macro attribution sources.
FRED_API_KEY=""
BEA_API_KEY=""
CENSUS_API_KEY=""

# Macro defaults.
ENABLE_DEFAULT_MACRO=true
GLOBAL_MACRO_MODE=false
ENABLE_GDELT=false

# Optional providers.
FMP_API_KEY=""
WISBURG_API_KEY=""
TIINGO_API_KEY=""
EODHD_API_KEY=""
EODHD_MAX_CALLS_PER_RUN=18
ENABLE_WISBURG=false

# Optional IC Copilot / LLM thesis synthesis.
# ChatGPT Plus does not automatically provide API credits for this app.
ENABLE_LLM_THESIS=false
ENABLE_LLM_CLAIM_VALIDATION=false
ENABLE_LLM_SOURCE_AGENT=false
ENABLE_SECONDARY_LLM_REVIEW=true
SECONDARY_LLM_MIN_STAGE="Research-Ready"
LLM_LANGUAGE_POLICY="bilingual_audit"
LLM_PRIMARY_PROFILE_ID=""
LLM_SECONDARY_PROFILE_ID=""
LLM_PROVIDER="deepseek"
LLM_MODEL="deepseek-v4-pro"
LLM_BASE_URL=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
QWEN_API_KEY=""
KIMI_API_KEY=""
DEEPSEEK_API_KEY=""
